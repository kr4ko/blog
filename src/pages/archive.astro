---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { t } from '../i18n';
import { formatArchiveDate, getBlogPosts, groupPostsByYear, postUrl } from '../utils/posts';

const blogPosts = await getBlogPosts();
const byYear = groupPostsByYear(blogPosts);
const i18n = t(site.language);
const canonicalUrl = new URL('/archive/', Astro.site).href;
---

<BaseLayout title={i18n.pageArchive} pageId="archive" canonicalUrl={canonicalUrl} hiddenPageTitle>
  <div class="archive-page">
    {blogPosts.length === 0 ? (
      <p class="empty-state">{i18n.noArchive}</p>
    ) : (
      [...byYear.entries()].map(([year, yearPosts]) => (
        <>
          <h2 class="archive-year">
            {year} <small>({yearPosts.length})</small>
          </h2>
          <ul class="archive-list">
            {yearPosts.map((post) => (
              <li class="archive-item">
                <span class="archive-date">{formatArchiveDate(post.data.date)}</span>
                <a class="archive-link" href={postUrl(post)}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </>
      ))
    )}
  </div>
</BaseLayout>
