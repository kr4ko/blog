---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../site.config';
import { absoluteUrl, siteHref } from '../../utils/paths';
import { formatDate, getBlogPosts, postUrl } from '../../utils/posts';

const blogPosts = await getBlogPosts();
const recentPosts = blogPosts.slice(0, 5);
const rssUrl = absoluteUrl('/rss.xml');
const atomUrl = absoluteUrl('/atom.xml');
const canonicalUrl = absoluteUrl('/feed/');
---

<BaseLayout
  title="Feed"
  description="RSS / Atom subscription information"
  pageId="feed"
  canonicalUrl={canonicalUrl}
>
  <div class="feed-page">
    <h1>Feed</h1>
    <p class="feed-intro">
      Subscribe with an RSS / Atom reader to receive new posts. This site is fully static and requires no account or JavaScript.
    </p>

    <div class="feed-card">
      <p class="feed-label">RSS URL</p>
      <p><a href={siteHref('/rss.xml')} class="feed-url">{rssUrl}</a></p>
      <p class="feed-label">Atom URL</p>
      <p><a href={siteHref('/atom.xml')} class="feed-url">{atomUrl}</a></p>
    </div>

    {recentPosts.length > 0 ? (
      <>
        <h2>Recent posts</h2>
        <ul class="feed-preview-list">
          {recentPosts.map((post) => (
            <li class="feed-preview-item">
              <span class="feed-preview-date">
                {formatDate(post.data.date, site.language)}
              </span>
              <a href={postUrl(post)}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="empty-state">No posts yet.</p>
    )}
  </div>
</BaseLayout>
