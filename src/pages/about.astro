---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { absoluteUrl } from '../utils/paths';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing src/content/pages/about.md');
const { Content } = await render(entry);
const pageTitle = entry.data.title;
const canonicalUrl = absoluteUrl('/about/');
---

<BaseLayout
  title="About"
  description={entry.data.summary ?? site.description}
  pageId="about"
  canonicalUrl={canonicalUrl}
>
  <div class="page-header">
    <h1>{pageTitle}</h1>
  </div>
  <div class="post-content">
    <Content />
  </div>
</BaseLayout>
