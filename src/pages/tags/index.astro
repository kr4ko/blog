---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../site.config';
import { getAllTags, getBlogPosts, tagUrl } from '../../utils/posts';

const blogPosts = await getBlogPosts();
const tags = getAllTags(blogPosts);
const tagCounts = tags.map((tag) => ({
  tag,
  count: blogPosts.filter((p) => p.data.tags.includes(tag)).length,
}));
tagCounts.sort((a, b) => b.count - a.count);
const canonicalUrl = new URL('/tags/', Astro.site).href;
---

<BaseLayout title="Tags" pageId="tags" canonicalUrl={canonicalUrl} hiddenPageTitle>
  <h1>Tags</h1>
  {tagCounts.length === 0 ? (
    <p class="empty-state">No tags yet.</p>
  ) : (
    <div class="tag-cloud">
      {tagCounts.map(({ tag, count }) => (
        <a href={tagUrl(tag)} class="tag-cloud-item">
          {tag} ({count})
        </a>
      ))}
    </div>
  )}
</BaseLayout>
